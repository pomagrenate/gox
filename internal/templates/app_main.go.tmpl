package main

import (
	"fmt"
	"net/http"
	"os"
)

func main() {
	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}

	fmt.Printf("Starting {{.Name}} service on port %s...\n", port)
	
	http.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
		fmt.Fprintf(w, "Hello from {{.Name}} service!")
	})

	if err := http.ListenAndServe(":"+port, nil); err != nil {
		fmt.Printf("Service failed to start: %v\n", err)
		os.Exit(1)
	}
}
